# Copy to .env and fill in the values. Never commit .env to git.

# JWT signing key — generate with:
#   openssl rand -base64 48
# or PowerShell:
#   [Convert]::ToBase64String((1..48 | %{ Get-Random -Max 256 }))
JWT_SECRET_KEY=REPLACE_ME_WITH_48_RANDOM_BYTES_BASE64
JWT_ISSUER=NutsApi
JWT_AUDIENCE=NutsAdmin

# Comma-separated list of allowed origins (your frontend URL)
CORS_ORIGINS=https://orehovysad.ru,https://www.orehovysad.ru

# Admin credentials
# Generate ADMIN_PASSWORD_HASH locally:
#   dotnet run --project src/Nuts.Api -- hash-password "YourStrongPassword"
# Copy the "salt:hash" output here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=REPLACE_ME_WITH_PBKDF2_SALT_COLON_HASH

# МойСклад API token (optional; leave empty to disable sync)
MOYSKLAD_TOKEN=

# OpenTelemetry OTLP endpoint (gRPC, :4317 usually). Leave empty to disable.
# For production behind TLS: https://otel.yourhost.ru:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
